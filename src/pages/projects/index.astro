---
import { getCollection } from 'astro:content';
// @ts-expect-error
import _ from 'lodash'
import Project from '@/components/Project.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
let allProjects = await getCollection('projects');
allProjects = _.orderBy(allProjects, 'data.launchYear', 'desc');
const pageTitle = 'Projects';
---

<BaseLayout pageTitle={pageTitle}>
  <h1 class="mb-10 text-5xl font-bold">Projects</h1>

  <div class="space-y-4 sm:grid sm:grid-cols-2 lg:grid-cols-4 sm:gap-4 xl:gap-8 sm:space-y-0 md:mt-12">
    {allProjects.map(project => <Project {...project.data} />)}
  </div>
</BaseLayout>
